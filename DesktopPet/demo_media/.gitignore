# Byte-compiled / optimized / DLL files
__pycache__/
*.py[cod]
*$py.class

# Virtual environments
env/
venv/
.venv/

# Distribution / packaging
build/
dist/
*.egg-info/

# IDE configuration files
.idea/
.vscode/

# Logs and test reports
*.log
*.tox/
*.coverage
*.coverage.*

# Jupyter Notebook checkpoints
.ipynb_checkpoints

# Temporary files
*.swp
*.swo

# Scikit-learn models
*.pkl
*.pkl.gz

# Ignore Python virtual environment folders for Docker or other containers
.docker/

# Ignore model weights for machine learning
*.h5
*.pth
*.pt
*.ckpt
*.tflite

# Ignore any files generated by AI or ML frameworks
*.onnx
